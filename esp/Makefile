# This is NOT generated by CMake!
# NOTE: You need to download the ESP-IDF and then source there to obtain access to idf.py.
.PHONY: all build flash monitor clean

all: build flash monitor

b build:
	idf.py build

f flash:
	idf.py flash

m monitor:
	idf.py monitor

c clean:
	idf.py fullclean

e esp esp32:
	idf.py --preview set-target esp32

l linux:
	idf.py --preview set-target linux
